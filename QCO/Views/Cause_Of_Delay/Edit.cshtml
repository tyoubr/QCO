@model QCO.Models.tbl_Cause_Of_Delay

@{
    ViewData["Title"] = "Edit";
}

@* Move the CSS below to an external stylesheet (e.g., site.css or a specific view's css file) and link it in _Layout.cshtml *@

<style>
    .container {
        max-width: 600px;
        margin: 30px auto;
        background-color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        padding: 20px;
    }

    .form-title {
        font-size: 1.8rem;
        font-weight: bold;
        color: #4e73df;
        margin-bottom: 20px;
        text-align: center;
    }

    .form-group {
        margin-bottom: 15px;
    }

        .form-group label {
            font-weight: 600;
            color: #5a5c69;
        }

        .form-group input, .form-group select {
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 10px;
            font-size: 1rem;
            width: 100%;
        }

            .form-group input:focus, .form-group select:focus {
                border-color: #4e73df;
                outline: none;
                box-shadow: 0 0 5px rgba(78, 115, 223, 0.5);
            }

    .is-invalid {
        border: 1px solid #e74a3b;
        box-shadow: 0 0 5px rgba(231, 74, 59, 0.5);
    }

    .btn-primary {
        background-color: #4e73df;
        border-color: #4e73df;
        font-size: 1rem;
        font-weight: 600;
        border-radius: 20px;
        padding: 10px 20px;
        display: block;
        width: 100%;
        text-align: center;
    }

        .btn-primary:hover {
            background-color: #2e59d9;
            border-color: #2653c3;
        }

    .back-link {
        display: block;
        margin-top: 20px;
        text-align: center;
        font-weight: bold;
        color: #4e73df;
        text-decoration: none;
    }

        .back-link:hover {
            text-decoration: underline;
        }

    .text-danger {
        font-size: 0.9rem;
        color: #e74a3b;
    }
</style>


<div class="container">
    <h1 class="form-title">Edit Cause of Delay</h1>
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <input type="hidden" asp-for="CAUSEID" />

        <div class="form-group">
            <label asp-for="CAUSE_OF_DELAY" class="control-label"></label> @* Label text comes from Data Annotations or Model.DisplayName *@
            <input asp-for="CAUSE_OF_DELAY" class="form-control" />
            <span asp-validation-for="CAUSE_OF_DELAY" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="REMARKS" class="control-label">GROUP</label>
            <select asp-for="REMARKS" class="form-control" id="REMARKS" name="REMARKS">
                <option value="">-- Select Group --</option>
                <option value="Man">Man</option>
                <option value="Machine">Machine</option>
                <option value="Method">Method</option>
                <option value="Material">Material</option>
            </select>
            @* The error span is already present and correctly styled. JavaScript will toggle its display. *@
            <span id="remarksError" class="text-danger" style="display:none;"></span>
        </div>

        <div class="form-group">
            <input type="submit" value="Save" class="btn btn-primary" />
        </div>
    </form>

    <a asp-action="Index" class="back-link">← Back to List</a>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("form").submit(function (e) {
                const remarksSelect = document.getElementById("REMARKS");
                const errorSpan = document.getElementById("remarksError");

                if (!remarksSelect.value) {
                    e.preventDefault(); // Prevents the default form submission
                    e.stopPropagation(); // Stops the event from bubbling up
                    remarksSelect.classList.add("is-invalid");
                    errorSpan.textContent = "Please select a group.";
                    errorSpan.style.display = "block";
                    return false; // Also returns false for older browser compatibility and jQuery events
                } else {
                    remarksSelect.classList.remove("is-invalid");
                    errorSpan.style.display = "none";
                    errorSpan.textContent = "";
                }
                return true; // Allow submission if valid
            });
        });
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}