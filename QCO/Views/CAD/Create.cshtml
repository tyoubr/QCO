    <script>
        let rowIndex = 0;

        $(document).ready(function () {

            // 🔹 Select2 Init
            $('#BookingNo').select2({
                placeholder: "Select Booking No",
                allowClear: true,
                minimumInputLength: 3,
                ajax: {
                    url: '@Url.Action("GetBookingNos", "CAD")',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        return { term: params.term };
                    },
                    processResults: function (data) {
                        return { results: data.results };
                    },
                    cache: true
                }
            });

            // 🔥 On Booking Select
            $('#BookingNo').on('select2:select', function (e) {

                let data = e.params.data;

                // Header Fill
                $('#Buyer').val(data.buyerName || '');
                $('#Season').val(data.season || 'N/A');
                $('#Seasonyear').val(data.seasonYear || 'N/A');
                $('#Job').val(data.jobNo || '');
                $('#Ir').val(data.irIb || '');
                $('#Brand').val(data.brand || 'N/A');
                $('#Styledes').val(data.styleDescription || 'N/A');

                // 🔹 Get Details (Multiple Color ভিত্তিক)
                $.ajax({
                    url: '@Url.Action("GetBookingDetails", "CAD")',
                    type: 'GET',
                    data: { jobNo: data.jobNo },
                    success: function (res) {

                        $('#detailsBody').empty();
                        rowIndex = 0;

                        res.forEach(item => {

                            addRow();

                            let row = $('#detailsBody tr').last();

                            // ✅ Auto Fill Only Required Fields
                            row.find(`[name="Details[${rowIndex - 1}].Gmntitem"]`).val(item.garmentsItem).prop('readonly', true);
                            row.find(`[name="Details[${rowIndex - 1}].Gmntcolor"]`).val(item.color).prop('readonly', true);
                            row.find(`[name="Details[${rowIndex - 1}].Fabricdes"]`).val(item.fabricDescription).prop('readonly', true);
                            row.find(`[name="Details[${rowIndex - 1}].Gsm"]`).val(item.gsm).prop('readonly', true);
                            row.find(`[name="Details[${rowIndex - 1}].Fabricusage"]`).val(item.fabricUsage).prop('readonly', true);
                        });
                    }
                });
            });

            // 🔹 Default 1 Row
            addRow();
        });

        // 🔹 Create Row
        function createRow(index) {
            return `
            <tr>
                <td><input name="Details[${index}].Gmntitem" class="gmntitem form-control" readonly /></td>
                <td><input name="Details[${index}].Gmntcolor" class="gmntcolor form-control" readonly /></td>
                <td><input name="Details[${index}].Fabricdes" class="fabricdes form-control" readonly /></td>
                <td><input name="Details[${index}].Gsm" class="gsm form-control" readonly /></td>
                <td><input name="Details[${index}].Fabricusage" class="fabricUsage form-control" readonly /></td>
                <td><input name="Details[${index}].Ptnnmbr" class="form-control" /></td>
                <td><input name="Details[${index}].Opt01" class="length form-control" /></td>
                <td><input name="Details[${index}].Fullwidth" class="width form-control" /></td>
                <td><input name="Details[${index}].Cutwidth" class="form-control" /></td>

                <td><input name="Details[${index}].Efficiency" class="form-control" /></td>
                <td><input name="Details[${index}].Sizeratio" class="form-control" /></td>

                <td><input name="Details[${index}].Markerqty" class="pcs form-control" /></td>
                <td><input name="Details[${index}].Wastage" class="allowance form-control" /></td>

                <td><input name="Details[${index}].Conspcs" class="conspcs form-control bg-light" readonly /></td>
                <td><input name="Details[${index}].Consdzn" class="consdzn form-control bg-light" readonly /></td>

                <td><input name="Details[${index}].Comments" class="form-control" /></td>
                <td><input type="file" name="Details[${index}].File" class="form-control" /></td>

                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-outline-success" onclick="addRow()">➕</button>
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeRow(this)">➖</button>
                </td>
            </tr>`;
        }

        // 🔹 Add Row
        function addRow() {
            $('#detailsBody').append(createRow(rowIndex));
            rowIndex++;
        }

        // 🔹 Remove Row
        function removeRow(btn) {
            if ($('#detailsBody tr').length > 1) {
                $(btn).closest('tr').remove();
            } else {
                alert("At least one row is required.");
            }
        }

        // 🔥 Auto Calculation
        $(document).on('input', '.length, .width, .gsm, .pcs, .allowance', function () {

            let row = $(this).closest('tr');

            let length = parseFloat(row.find('.length').val()) || 0;
            let width = parseFloat(row.find('.width').val()) || 0;
            let gsm = parseFloat(row.find('.gsm').val()) || 0;
            let pcs = parseFloat(row.find('.pcs').val()) || 0;
            let allowance = (parseFloat(row.find('.allowance').val()) || 0) / 100;

            if (length && width && gsm && pcs) {

                let base = (length * width * gsm) / 1550 / 1000 / pcs;

                let consPcs = base + (base * allowance);
                let consDzn = consPcs * 12;

                row.find('.conspcs').val(consPcs.toFixed(2));
                row.find('.consdzn').val(consDzn.toFixed(2));

            } else {
                row.find('.conspcs, .consdzn').val('');
            }
        });

    </script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const chk = document.getElementById("independentChk");
            const select = $("#BookingNo");
            const input = document.getElementById("StylerefInput");
            const jobInput = document.getElementById("Job");
            const irInput = document.getElementById("Ir");
            const buyerInput = document.getElementById("Buyer");
            const brandInput = document.getElementById("Brand");
            const seasonInput = document.getElementById("Season");
            const seasonyearInput = document.getElementById("Seasonyear");
            const styledesInput = document.getElementById("Styledes");

            chk.addEventListener("change", function () {

                if (this.checked) {

                    // hide select2 UI properly
                    select.next(".select2").hide();
                    select.val(null).trigger("change");

                    // show input
                    input.classList.remove("d-none");

                    // 🔥 Job editable
                    jobInput.removeAttribute("readonly");
                    jobInput.classList.remove("bg-light");

                    //IR/this.ATTRIBUTE_NODE editable
                    irInput.removeAttribute("readonly");
                    irInput.classList.remove("bg-light");

                    buyerInput.removeAttribute("readonly");
                    buyerInput.classList.remove("bg-light");

                    brandInput.removeAttribute("readonly");
                    brandInput.classList.remove("bg-light");

                    seasonInput.removeAttribute("readonly");
                    seasonInput.classList.remove("bg-light");

                    seasonyearInput.removeAttribute("readonly");
                    seasonyearInput.classList.remove("bg-light");

                    styledesInput.removeAttribute("readonly");
                    styledesInput.classList.remove("bg-light");

                } else {

                    // show select2 UI
                    select.next(".select2").show();

                    // hide input
                    input.classList.add("d-none");

                    // 🔥 Job readonly again
                    jobInput.setAttribute("readonly", true);
                    jobInput.classList.add("bg-light");
                    // 🔥 IR/IB readonly again
                    irInput.setAttribute("readonly", true);
                    irInput.classList.add("bg-light");

                    buyerInput.setAttribute("readonly", true);
                    buyerInput.classList.add("bg-light");

                    brandInput.setAttribute("readonly", true);
                    brandInput.classList.add("bg-light");

                    seasonInput.setAttribute("readonly", true);
                    seasonInput.classList.add("bg-light");

                    seasonyearInput.setAttribute("readonly", true);
                    seasonyearInput.classList.add("bg-light");

                    styledesInput.setAttribute("readonly", true);
                    styledesInput.classList.add("bg-light");

                }
            });

        });
    </script>
}