    <script>
        let rowIndex = 0;

        // Generate a new row HTML
        function createRow(index) {
            return `
            <tr>
                <td><input name="Details[${index}].Ptnnmbr" class="form-control" /></td>
                <td><input name="Details[${index}].Gmntitem" class="form-control" /></td>
                <td><input name="Details[${index}].Gmntcolor" class="form-control" /></td>
                <td><input name="Details[${index}].Fabricdes" class="form-control" /></td>
                <td><input name="Details[${index}].Fabricusage" class="form-control" /></td>
                <td><input name="Details[${index}].Gsm" type="number" step="0.01" class="form-control" /></td>
                <td><input name="Details[${index}].Fullwidth" type="number" step="0.01" class="form-control" /></td>
                <td><input name="Details[${index}].Cutwidth" type="number" step="0.01" class="form-control" /></td>
                <td><input name="Details[${index}].Efficiency" type="number" step="0.01" class="form-control" /></td>
                <td><input name="Details[${index}].Sizeratio" class="form-control" /></td>
                <td><input name="Details[${index}].Markerqty" type="number" step="0.01" class="form-control" /></td>
                <td><input name="Details[${index}].Conspcs" type="number" step="0.01" class="form-control" /></td>
                <td><input name="Details[${index}].Consdzn" type="number" step="0.01" class="form-control" /></td>
                <td><input name="Details[${index}].Wastage" type="number" step="0.01" class="form-control" /></td>
                <td><input name="Details[${index}].Comments" class="form-control" /></td>
                <td class="text-center">
                          <button type="button" class="btn btn-sm btn-outline-success" onclick="addRow()">➕</button>
                <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeRow(this)">➖</button>
                </td>
            </tr>`;
        }

        // Add new row
        function addRow() {
            const tbody = document.getElementById("detailsBody");
            tbody.insertAdjacentHTML("beforeend", createRow(rowIndex));
            rowIndex++;
        }

        // Remove row (keep at least one)
        function removeRow(btn) {
            const tbody = document.getElementById("detailsBody");

            if (tbody.rows.length > 1) {
                btn.closest("tr").remove();
            } else {
                alert("At least one row is required.");
            }
        }

        // Initialize with one row
        document.addEventListener("DOMContentLoaded", function () {
            addRow();
        });
    </script>
