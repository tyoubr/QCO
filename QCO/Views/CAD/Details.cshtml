@model QCO.ViewModel.CadConsumptionViewModel

@{
    ViewData["Title"] = "Details";
}

<h2 class="text-primary text-center">CAD Consumption Details</h2>
<hr />

<div class="container bg-light p-4 rounded shadow-sm">

    <!-- MASTER INFO -->
    <h4 class="text-success">General Information</h4>
    <table class="table table-bordered">
        <tr>
            <th>CAD Date</th>
            <td>@Model.Master?.Caddate.Value.ToString("dd-MM-yyyy")</td>

            <th>Company</th>
            <td>@Model.Master.Opt01</td>
        </tr>
        <tr>
            <th>Style Ref</th>
            <td>@Model.Master.Styleref</td>

            <th>Buyer</th>
            <td>@Model.Master.Buyer</td>
        </tr>
        <tr>
            <th>Brand</th>
            <td>@Model.Master.Brand</td>

            <th>Season</th>
            <td>@Model.Master.Season</td>
        </tr>
        <tr>
            <th>Season Year</th>
            <td>@Model.Master.Seasonyear</td>

            <th>Consumption For</th>
            <td>@Model.Master.Consfor</td>
        </tr>
        <tr>
            <th>Pattern Master</th>
            <td>@Model.Master.Patternmaster</td>

            <th>Approval Status</th>
            <td>@((Model.Master.Isapproved ?? false) ? "Approved" : "Pending Approval")</td>
        </tr>
        <tr>
            <th>Comments</th>
            <td colspan="3">@Model.Master.Comments</td>
        </tr>
    </table>

    <!-- DETAILS TABLE -->
    <h4 class="text-success mt-4">Marker Details</h4>

    @if (Model.Details != null && Model.Details.Any())
    {
        foreach (var item in Model.Details)
        {
            <div class="border rounded p-3 mb-3 bg-light">

                <div class="row mb-1">
                    <div class="col-5 fw-bold">Ptn No</div>
                    <div class="col-7">: @item.Ptnnmbr</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">Item</div>
                    <div class="col-7">: @item.Gmntitem</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">Color</div>
                    <div class="col-7">: @item.Gmntcolor</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">Fabric</div>
                    <div class="col-7">: @item.Fabricdes</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">Usage</div>
                    <div class="col-7">: @item.Fabricusage</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">GSM</div>
                    <div class="col-7">: @item.Gsm</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">Marker Length</div>
                    <div class="col-7">: @item.Opt01</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">Full W</div>
                    <div class="col-7">: @item.Fullwidth</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">Cut W</div>
                    <div class="col-7">: @item.Cutwidth</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">Eff %</div>
                    <div class="col-7">: @item.Efficiency</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">Size</div>
                    <div class="col-7">: @item.Sizeratio</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">Qty</div>
                    <div class="col-7">: @item.Markerqty</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">Cons/Pcs</div>
                    <div class="col-7">: @item.Conspcs</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">Cons/Dzn</div>
                    <div class="col-7">: @item.Consdzn</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">Wastage</div>
                    <div class="col-7">: @item.Wastage</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">Comments</div>
                    <div class="col-7">: @item.Comments</div>
                </div>

                <div class="row mb-1">
                    <div class="col-5 fw-bold">File</div>
                    <div class="col-7">
                        @if (!string.IsNullOrEmpty(item.Filepath))
                        {
                            var file = System.IO.Path.GetFileName(item.Filepath);

                            var originalName = file.Contains("_")
                            ? file.Substring(file.IndexOf("_") + 1)
                            : file;

                            <div class="mb-1">📄 @originalName</div>

                            <a asp-action="DownloadFile"
                               asp-route-id="@item.Caddid"
                               class="btn btn-sm btn-outline-primary">
                                Download
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No File</span>
                        }
                    </div>
                </div>

            </div>
        }
    }
    else
    {
        <div class="text-center text-danger">
            No details found
        </div>
    }

    <!-- BACK BUTTON -->
    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>

</div>